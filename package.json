{
  "name": "dk-safety",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node scripts/dev-safe.mjs",
    "dev:raw": "next dev",
    "dev:turbopack": "next dev --turbopack",
    "dev:webpack": "next dev",
    "clean": "node scripts/clean-next.mjs",
    "build": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "sync:supabase": "node scripts/sync-local-to-supabase.mjs",
    "db:apply": "node --env-file=.env.local scripts/apply-supabase-schema.mjs",
    "db:sync-env": "node scripts/sync-db-env.mjs",
    "storage:ensure": "node --env-file=.env.local scripts/ensure-supabase-storage.mjs",
    "verify:supabase": "node --env-file=.env.local scripts/verify-supabase-connection.mjs",
    "env:production": "node -e \"require('fs').copyFileSync('.env.example','.env.production'); console.log('Wrote .env.production from .env.example');\"",
    "setup:deploy": "node scripts/setup-github-vercel.mjs",
    "cron:test": "node --env-file=.env.local scripts/test-morning-cron.mjs",
    "intel:test": "node --env-file=.env.local scripts/test-market-intelligence.mjs",
    "harness:api": "tsx tests/harness/api.test.ts",
    "harness:db": "tsx tests/harness/db.test.ts",
    "harness:domains": "tsx tests/harness/domains.test.ts",
    "harness:all": "npm run harness:api && npm run harness:db && npm run harness:domains"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.80",
    "@supabase/supabase-js": "^2.104.1",
    "@types/pdf-parse": "^1.1.5",
    "lucide-react": "^1.14.0",
    "next": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.4",
    "solapi": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.0.0",
    "postgres": "^3.4.9",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
