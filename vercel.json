{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/cron/morning-report",
      "schedule": "54 18 6 6 *"
    },
    {
      "path": "/api/cron/morning-report",
      "schedule": "0 23 * * 5"
    },
    {
      "path": "/api/cron/content-performance-review",
      "schedule": "0 22 * * 0"
    },
    {
      "path": "/api/cron/content-plan",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/content-draft",
      "schedule": "0 0 * * 2"
    },
    {
      "path": "/api/cron/content-approval-notify",
      "schedule": "0 23 * * 2"
    },
    {
      "path": "/api/cron/market-intelligence",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/external-knowledge-collect",
      "schedule": "0 21 * * 6"
    }
  ]
}
