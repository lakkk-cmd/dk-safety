{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/cron/morning-report",
      "schedule": "0 23 * * 5"
    },
    {
      "path": "/api/cron/content-performance-review",
      "schedule": "0 22 * * 0"
    },
    {
      "path": "/api/cron/market-intelligence",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/daily-business-scan",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/external-knowledge-collect",
      "schedule": "0 21 * * 6"
    },
    {
      "path": "/api/cron/weekly-system-check",
