NEXT_PUBLIC_BUSINESS_PHONE=010-1234-5678
NEXT_PUBLIC_KAKAO_OPENCHAT_URL=https://open.kakao.com/
NEXT_PUBLIC_APP_URL=http://www.dkansim.com
NEXT_PUBLIC_DEFAULT_DISPATCH_FEE=50000
ADMIN_PASSWORD=change-this-password
NEXT_PUBLIC_SUPABASE_URL=
# 클라이언트용. 레거시 anon JWT(eyJ…) 또는 신규 sb_publishable_…
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 신규 키: sb_secret_… (RLS 우회)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATA_BUCKET=dk-safety-data
SUPABASE_UPLOAD_BUCKET=dk-safety-uploads
# 비우면 NEXT_PUBLIC_SUPABASE_URL + /storage/v1/object/public/{SUPABASE_UPLOAD_BUCKET} 로 자동 조합
SUPABASE_UPLOAD_PUBLIC_BASE_URL=
# Postgres 예약/기사/작업 모드 (스키마 적용 후 true 권장, npm run db:sync-env 로 자동 동기화)
# true 인 경우 NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY 가 모두 있어야 서버가 DB에 연결됩니다(없으면 500 대신 404/비활성 UI).
DK_SAFETY_USE_SUPABASE_DB=false
# 기사 세션 쿠키 서명용 임의 문자열 (운영에서 필수, 비어 있으면 db:sync-env 가 생성)
WORKER_SESSION_SECRET=
# 스키마 적용용 DB 연결 URI (Dashboard → Database → Connection string). 적용: npm run db:apply
DATABASE_URL=

# --- AI 경영진 사령부 (023 마이그레이션, Cron, 이메일 보고) ---
# Anthropic Claude API (6인 경영진 + 총괄). https://console.anthropic.com/
ANTHROPIC_API_KEY=
# 선택. 미설정 시 claude-sonnet-4-6
ANTHROPIC_MODEL=
# Vercel Cron 인증 (64자 이상 랜덤 hex 권장). 로컬: Authorization: Bearer {CRON_SECRET}
CRON_SECRET=
# 일일 보고 수신 이메일
REPORT_EMAIL=
# Resend (https://resend.com) — 발신 도메인 report@dkansim.com 인증 필요
RESEND_API_KEY=

# --- 유튜브/Gemini 인사이트 파이프라인 ---
# YouTube Data API v3 (https://console.cloud.google.com/apis/library/youtube.googleapis.com)
YOUTUBE_API_KEY=
# Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# 선택. 미설정 시 gemini-2.0-flash
GEMINI_MODEL=

# --- 콘텐츠 마케팅 사령부 (contents.dkansim.com, 026 마이그레이션) ---
# 유튜브 업로드용 OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
# 리디렉션 URI: https://contents.dkansim.com/api/auth/youtube/callback (로컬: http://localhost:3000/api/auth/youtube/callback)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# 선택. 미설정 시 NEXT_PUBLIC_APP_URL 기반으로 자동 조합
YOUTUBE_REDIRECT_URI=
# 네이버 검색 API — 트렌드 키워드/경쟁 블로그 분석 (https://developers.naver.com/apps)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 카카오 "나에게 보내기" 메모 — 콘텐츠 승인 알림 + 카카오 포스트 발행 (/api/kakao/callback에서 발급)
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
