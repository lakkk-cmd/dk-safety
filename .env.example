NEXT_PUBLIC_BUSINESS_PHONE=010-1234-5678
NEXT_PUBLIC_KAKAO_OPENCHAT_URL=https://open.kakao.com/
NEXT_PUBLIC_APP_URL=http://www.dkansim.com
NEXT_PUBLIC_DEFAULT_DISPATCH_FEE=50000
ADMIN_PASSWORD=change-this-password
NEXT_PUBLIC_SUPABASE_URL=
# 클라이언트용. 레거시 anon JWT(eyJ…) 또는 신규 sb_publishable_…
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 신규 키: sb_secret_… (RLS 우회)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATA_BUCKET=dk-safety-data
SUPABASE_UPLOAD_BUCKET=dk-safety-uploads
# 비우면 NEXT_PUBLIC_SUPABASE_URL + /storage/v1/object/public/{SUPABASE_UPLOAD_BUCKET} 로 자동 조합
SUPABASE_UPLOAD_PUBLIC_BASE_URL=
# Postgres 예약/기사/작업 모드 (스키마 적용 후 true 권장, npm run db:sync-env 로 자동 동기화)
# true 인 경우 NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY 가 모두 있어야 서버가 DB에 연결됩니다(없으면 500 대신 404/비활성 UI).
DK_SAFETY_USE_SUPABASE_DB=false
# 기사 세션 쿠키 서명용 임의 문자열 (운영에서 필수, 비어 있으면 db:sync-env 가 생성)
WORKER_SESSION_SECRET=
# 스키마 적용용 DB 연결 URI (Dashboard → Database → Connection string). 적용: npm run db:apply
DATABASE_URL=
